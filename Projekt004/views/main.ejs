<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', {title: "Ekran główny myTodos"}) %>
<body>
    <div class="cssMain">
        <h2 class="cssH2Time">Aktualna data i godzina:</h2><p><%= currentTime %></p>

        <h2>myTodos:</h2>
        <table>
            <tr>
                <th>Opis wydarzenia</th>
                <th>Deadline wydarzenia</th>
                <th>Edycja pojedynczego rekordu</th>
                <th>Usuwanie pojdeynczego rekordu</th>
            </tr>
            <% messages.forEach(msg => { 
                const isOverdue = new Date(msg.expirationDate) < new Date();
                const className = isOverdue ? 'overdue' : '';
            %>
            <tr>
                <td class="<%= className %>"><%= msg.messages %></td>
                <td class="<%= className %>"><%= msg.expirationDate %></td>
                <td>
                    <form method="get" action="/edit/<%= msg.id %>">
                    <button class="cssEdit">Edytuj</button></form>
                </td>
                <td>
                    <form method="POST" action="/main/delete/<%= msg.id %>">
                    <button class="cssDel">Usuń</button></form>
                </td>
            </tr>
            <% }); %>
        </table>

        <h2>Dodaj wiadomość:</h2>
        <form method="POST" action="/main/message">
            <label>Opis wydarzenia</label>
            <input type="text" name="message" placeholder="twoja wiadomość..." required><br>
            <label>Deadline wydarzenia</label>
            <input type="date" name="date" required><br>
            <button type="submit" class="cssSend">Wyslij</button>
        </form>

        <h2>Usun dane</h2>
        <form method="POST" action="/main/clear">
            <button type="submit" class="cssByeBye">Bye bye dane</button>
        </form>
        <% if(!isAdmin) { %>
        <form method="POST" action="/main/adminPanel" >
            <button type="submit">Panel Administratora</button>    
        </form>
        <% } %>

        <form action="/main/logout" method="post">
            <button type="submit">Wyloguj</button>    
        </form>
    </div>
</body>
</html>