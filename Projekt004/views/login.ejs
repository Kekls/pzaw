<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', {title: "Zaloguj do myTodos"}) %>
<body>
    <div class="cssMain">
        <form method="POST" action="/login">
            <div style="color: red; display: <%= error ? 'block' : 'none' %>"><%= error %></div>
            <label>login: </label><input type="text" name="login" value="<%= login %>" required><br>
            <label>hasło: </label><input type="password" name="password" value="<%= password %>" required><br>
            <button type="submit">zaloguj</button>
        </form>

        <a href="/register">rejestracja</a>
    </div>
</body>
</html>